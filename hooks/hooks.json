{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ensure-auth.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__ga-mcp-full__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pretool-auth-check.sh"
          }
        ]
      }
    ]
  }
}
